<UserControl x:Class="AdaptiveVolumeMixer.Controls.LevelItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AdaptiveVolumeMixer.ViewModels"
             xmlns:l="clr-namespace:AdaptiveVolumeMixer.Converters">
    <!--
        层级项控件：展示单个层级的标题栏、进程列表和空状态
        DataContext: LevelViewModel
    -->

    <Border Style="{StaticResource LevelDropTargetStyle}"
            AllowDrop="True"
            DragEnter="LevelBorder_DragEnter"
            DragOver="LevelBorder_DragOver"
            DragLeave="LevelBorder_DragLeave"
            Drop="LevelBorder_Drop">
        <StackPanel>

            <!-- ===== 层级标题栏 ===== -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- 颜色条 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 名称 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 进程计数 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 音量滑块 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 占位 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 删除按钮 -->
                </Grid.ColumnDefinitions>

                <!-- 颜色条 -->
                <Border Grid.Column="0"
                        Width="8"
                        CornerRadius="6,0,0,0"
                        Background="{Binding LevelIndex, Converter={StaticResource LevelIndexToColor}}"/>

                <!-- 可编辑的显示名称 -->
                <TextBox Grid.Column="1"
                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16"
                         FontWeight="Bold"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{Binding LevelIndex, Converter={StaticResource LevelIndexToColor}}"
                         VerticalAlignment="Center"
                         Margin="10,8,0,8"
                         MinWidth="80"/>

                <!-- 进程计数 -->
                <TextBlock Grid.Column="2"
                           Text="{Binding ProcessCount}"
                           Style="{StaticResource ThinMutedStyle}"
                           VerticalAlignment="Center"
                           Margin="4,0,8,0"/>

                <!-- 目标音量滑块（最高优先级层级隐藏） -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsHighestPriority, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock Text="{l:Loc Label.TargetVolume}"
                               Style="{StaticResource ThinSecondaryStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <Slider Value="{Binding SuppressRatio}"
                            Minimum="0"
                            Maximum="1"
                            SmallChange="0.05"
                            LargeChange="0.1"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Width="100"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuppressRatioPercent}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#555"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               MinWidth="30"/>
                </StackPanel>

                <!-- 删除层级按钮（最高优先级层级隐藏） -->
                <Button Grid.Column="5"
                        Content="✕"
                        Command="{Binding DataContext.RemoveLevelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource DeleteIconButtonStyle}"
                        ToolTip="{l:Loc Tooltip.DeleteLevel}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,4,0"
                        Visibility="{Binding IsHighestPriority, Converter={StaticResource InverseBoolToVisibility}}"/>
            </Grid>

            <!-- ===== 进程列表 ===== -->
            <ItemsControl ItemsSource="{Binding Processes}"
                          Margin="8,0,8,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LevelItemViewModel">
                        <Border Style="{StaticResource ProcessItemStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 进程名 -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FullDisplayName}"
                                           FontWeight="Medium"
                                           FontSize="13"/>

                                <!-- 音量 -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding VolumeText}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#333"
                                           Margin="10,0,8,0"
                                           VerticalAlignment="Center"/>

                                <!-- 状态 -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding StatusText}"
                                           FontSize="11"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource IdleColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaying}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource PlayingColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSuppressed}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource SuppressedColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 删除按钮 -->
                                <Button Grid.Column="3"
                                        Content="✕"
                                        Tag="{Binding}"
                                        Click="RemoveProcessButton_Click"
                                        Style="{StaticResource DeleteIconButtonStyle}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- 空状态 -->
            <TextBlock Text="{l:Loc Hint.NoProcesses}"
                       FontSize="11"
                       Foreground="#BBB"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"
                       Visibility="{Binding HasProcesses, Converter={StaticResource InverseBoolToVisibility}}"/>
        </StackPanel>
    </Border>
</UserControl>
