<Window x:Class="AdaptiveVolumeMixer.ExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:AdaptiveVolumeMixer.Converters"
        Title="Adaptive Volume Mixer"
        Height="210"
        Width="340"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei, Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{l:Loc ExitDialog.Title}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="#333"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button x:Name="ExitButton"
                    Content="{l:Loc ExitDialog.Exit}"
                    Width="130"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#F44336"
                    Foreground="White"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="ExitButton_Click"/>
            <Button x:Name="TrayButton"
                    Content="{l:Loc ExitDialog.MinimizeToTray}"
                    Width="130"
                    Height="50"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#2196F3"
                    Foreground="White"
                    Cursor="Hand"
                    Click="TrayButton_Click"/>
        </StackPanel>

        <CheckBox x:Name="RememberCheckBox"
                  Grid.Row="2"
                  Content="{l:Loc ExitDialog.Remember}"
                  IsChecked="False"
                  FontSize="11"
                  Foreground="#666"
                  HorizontalAlignment="Center"
                  Margin="0,15,0,0"/>
    </Grid>
</Window>
