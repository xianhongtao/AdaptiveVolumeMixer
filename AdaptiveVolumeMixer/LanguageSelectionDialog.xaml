<Window x:Class="AdaptiveVolumeMixer.LanguageSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language / 语言"
        Height="200"
        Width="340"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei, Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="请选择语言 / Please select language"
                   FontSize="15"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="#333"
                   Margin="0,0,0,20"/>

        <!-- 语言按钮 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button x:Name="ChineseButton"
                    Content="🇨🇳  中文"
                    Width="130"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#2196F3"
                    Foreground="White"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="ChineseButton_Click"/>
            <Button x:Name="EnglishButton"
                    Content="🇺🇸  English"
                    Width="130"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    Cursor="Hand"
                    Click="EnglishButton_Click"/>
        </StackPanel>

        <!-- 勾选框: 记住选择 -->
        <CheckBox x:Name="RememberCheckBox"
                  Grid.Row="2"
                  Content="记住选择，下次不再询问 / Remember choice"
                  IsChecked="False"
                  FontSize="11"
                  Foreground="#666"
                  HorizontalAlignment="Center"
                  Margin="0,15,0,0"/>
    </Grid>
</Window>
