<Window x:Class="AdaptiveVolumeMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AdaptiveVolumeMixer.ViewModels"
        xmlns:local="clr-namespace:AdaptiveVolumeMixer"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        Title="Adaptive Volume Mixer - 自适应音量合成器"
        Height="700"
        Width="950"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei, Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 布尔值转可见性转换器 -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <local:NullToBoolConverter x:Key="NullToBool"/>

        <!-- 层级背景色 -->
        <SolidColorBrush x:Key="Level0Bg"
                         Color="#1A237E"/>
        <SolidColorBrush x:Key="Level1Bg"
                         Color="#283593"/>
        <SolidColorBrush x:Key="Level2Bg"
                         Color="#303F9F"/>
        <SolidColorBrush x:Key="Level3Bg"
                         Color="#3949AB"/>
        <SolidColorBrush x:Key="Level4Bg"
                         Color="#3F51B5"/>
        <SolidColorBrush x:Key="Level5Bg"
                         Color="#5C6BC0"/>

        <!-- 状态颜色 -->
        <SolidColorBrush x:Key="PlayingColor"
                         Color="#4CAF50"/>
        <SolidColorBrush x:Key="SuppressedColor"
                         Color="#FF9800"/>
        <SolidColorBrush x:Key="IdleColor"
                         Color="#9E9E9E"/>

        <Style x:Key="LevelHeaderStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="16"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource Level0Bg}"/>
            <Setter Property="Margin"
                    Value="10,8,0,8"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}"
                             Value="-1">
                    <Setter Property="Foreground"
                            Value="{StaticResource Level1Bg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}"
                             Value="-2">
                    <Setter Property="Foreground"
                            Value="{StaticResource Level2Bg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}"
                             Value="-3">
                    <Setter Property="Foreground"
                            Value="{StaticResource Level3Bg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}"
                             Value="-4">
                    <Setter Property="Foreground"
                            Value="{StaticResource Level4Bg}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}"
                             Value="-5">
                    <Setter Property="Foreground"
                            Value="{StaticResource Level5Bg}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProcessItemStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#F5F5F5"/>
            <Setter Property="BorderBrush"
                    Value="#E0E0E0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="4"/>
            <Setter Property="Margin"
                    Value="4,2"/>
            <Setter Property="Padding"
                    Value="8,6"/>
        </Style>

        <Style x:Key="SectionHeaderStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="#333333"/>
            <Setter Property="Margin"
                    Value="0,10,0,5"/>
        </Style>

        <!-- 拖拽悬停时层级边框高亮 -->
        <Style x:Key="LevelDropTargetStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#FAFAFA"/>
            <Setter Property="CornerRadius"
                    Value="6"/>
            <Setter Property="Margin"
                    Value="0,0,0,8"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="BorderBrush"
                    Value="#E0E0E0"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Style.Triggers>
                <Trigger Property="Tag"
                         Value="DragOver">
                    <Setter Property="BorderBrush"
                            Value="#2196F3"/>
                    <Setter Property="BorderThickness"
                            Value="2"/>
                    <Setter Property="Background"
                            Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0"
                Background="#F0F0F0"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎚️"
                               FontSize="24"
                               Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Adaptive Volume Mixer"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1A237E"/>
                        <TextBlock Text="自适应音量合成器"
                                   FontSize="11"
                                   Foreground="#666"/>
                    </StackPanel>
                </StackPanel>

                <!-- 状态 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#555"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button Content="▶ 启动监控"
                            Command="{Binding StartMonitoringCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="12,6"
                            Margin="0,0,6,0"
                            Visibility="{Binding IsNotMonitoring, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="⏹ 停止监控"
                            Command="{Binding StopMonitoringCommand}"
                            Background="#F44336"
                            Foreground="White"
                            Padding="12,6"
                            Margin="0,0,6,0"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="🔄 刷新进程"
                            Command="{Binding RefreshProcessesCommand}"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="12,6"
                            Margin="0,0,6,0"/>
                    <Button Content="💾 保存配置"
                            Command="{Binding SaveConfigCommand}"
                            Background="#607D8B"
                            Foreground="White"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主体内容 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：层级列表 ===== -->
            <ScrollViewer Grid.Column="0"
                          Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="📊 层级管理"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <ItemsControl ItemsSource="{Binding Levels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:LevelViewModel">
                                <Border Style="{StaticResource LevelDropTargetStyle}"
                                        AllowDrop="True"
                                        DragEnter="LevelBorder_DragEnter"
                                        DragOver="LevelBorder_DragOver"
                                        DragLeave="LevelBorder_DragLeave"
                                        Drop="LevelBorder_Drop">
                                    <StackPanel>
                                        <!-- 层级标题 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="8"
                                                    CornerRadius="6,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource Level0Bg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}"
                                                                         Value="-1">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource Level1Bg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}"
                                                                         Value="-2">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource Level2Bg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}"
                                                                         Value="-3">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource Level3Bg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}"
                                                                         Value="-4">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource Level4Bg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}"
                                                                         Value="-5">
                                                                <Setter Property="Background"
                                                                        Value="{StaticResource Level5Bg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       Style="{StaticResource LevelHeaderStyle}"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ProcessCount}"
                                                       FontSize="11"
                                                       Foreground="#999"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                        </Grid>

                                        <!-- 进程列表 -->
                                        <ItemsControl ItemsSource="{Binding Processes}"
                                                      Margin="8,0,8,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:LevelItemViewModel">
                                                    <Border Style="{StaticResource ProcessItemStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 进程名 -->
                                                            <StackPanel Grid.Column="0"
                                                                        Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="Medium"
                                                                           FontSize="13"/>
                                                                <TextBlock Text=" ("
                                                                           FontSize="11"
                                                                           Foreground="#999"/>
                                                                <TextBlock Text="{Binding ProcessName}"
                                                                           FontSize="11"
                                                                           Foreground="#999"/>
                                                                <TextBlock Text=")"
                                                                           FontSize="11"
                                                                           Foreground="#999"/>
                                                            </StackPanel>

                                                            <!-- 音量 -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding VolumeText}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="#333"
                                                                       Margin="10,0,8,0"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- 状态 -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding StatusText}"
                                                                       FontSize="11"
                                                                       Margin="0,0,8,0"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource IdleColor}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPlaying}"
                                                                                         Value="True">
                                                                                <Setter Property="Foreground"
                                                                                        Value="{StaticResource PlayingColor}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsSuppressed}"
                                                                                         Value="True">
                                                                                <Setter Property="Foreground"
                                                                                        Value="{StaticResource SuppressedColor}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <!-- 删除按钮 -->
                                                            <Button Grid.Column="3"
                                                                    Content="✕"
                                                                    Tag="{Binding}"
                                                                    Click="RemoveProcessButton_Click"
                                                                    Background="Transparent"
                                                                    Foreground="#F44336"
                                                                    BorderThickness="0"
                                                                    FontSize="14"
                                                                    Width="24"
                                                                    Height="24"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <!-- 空状态 -->
                                        <TextBlock Text="（暂无进程，请从右侧拖拽添加）"
                                                   FontSize="11"
                                                   Foreground="#BBB"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== 右侧：控制面板 ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 可用进程列表（占据剩余空间） -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🎯 可用音频进程"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Background="#FAFAFA"
                                CornerRadius="6"
                                Padding="8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <ListBox x:Name="AvailableProcessListBox"
                                         ItemsSource="{Binding AvailableProcesses}"
                                         SelectedItem="{Binding SelectedAvailableProcess}"
                                         Margin="0,0,0,8"
                                         PreviewMouseMove="AvailableProcessListBox_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Medium"/>
                                                <TextBlock Text=" ("
                                                           FontSize="11"
                                                           Foreground="#999"/>
                                                <TextBlock Text="{Binding ProcessName}"
                                                           FontSize="11"
                                                           Foreground="#999"/>
                                                <TextBlock Text=")"
                                                           FontSize="11"
                                                           Foreground="#999"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="💡 拖拽上方进程到左侧层级即可添加"
                                           FontSize="11"
                                           Foreground="#999"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 使用说明（固定在底部） -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="ℹ️ 使用说明"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Background="#FFF8E1"
                            CornerRadius="6"
                            Padding="10"
                            BorderBrush="#FFE082"
                            BorderThickness="1">
                        <StackPanel TextBlock.FontSize="11"
                                    TextBlock.Foreground="#666">
                            <TextBlock Text="1. 从右侧「可用音频进程」拖拽到左侧层级即可添加"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="2. 点击「启动监控」开始自动音量调节"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="3. 当上级软件播放声音时，下级音量自动降至20%"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="4. 层级0为最高优先级，层级-5为最低"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="5. 配置会自动保存到 config.json"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== 底部状态栏 ===== -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="💡"
                           FontSize="14"
                           Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="#666"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           FontSize="11"
                           Foreground="#999"
                           VerticalAlignment="Center"
                           Text="{Binding IsMonitoring, StringFormat='层级: 6 | 监控: {0}'}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
