<Window x:Class="AdaptiveVolumeMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AdaptiveVolumeMixer.ViewModels"
        xmlns:controls="clr-namespace:AdaptiveVolumeMixer.Controls"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        Title="Adaptive Volume Mixer - 自适应音量合成器"
        Height="700"
        Width="950"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing"
        StateChanged="MainWindow_StateChanged"
        FontFamily="Microsoft YaHei, Segoe UI">

    <Window.Resources>
        <!-- 局部样式（仅 MainWindow 使用） -->

        <Style x:Key="SectionHeaderStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="#333333"/>
            <Setter Property="Margin"
                    Value="0,10,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0"
                Background="#F0F0F0"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎚️"
                               FontSize="24"
                               Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Adaptive Volume Mixer"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1A237E"/>
                        <TextBlock Text="自适应音量合成器"
                                   FontSize="11"
                                   Foreground="#666"/>
                    </StackPanel>
                </StackPanel>

                <!-- 状态 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="#555"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button Content="▶ 启动监控"
                            Command="{Binding StartMonitoringCommand}"
                            Background="#4CAF50"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Visibility="{Binding IsNotMonitoring, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="⏹ 停止监控"
                            Command="{Binding StopMonitoringCommand}"
                            Background="#F44336"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="🔄 刷新进程"
                            Command="{Binding RefreshAvailableProcessesCommand}"
                            Background="#2196F3"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button Content="➕ 添加层级"
                            Command="{Binding AddLevelCommand}"
                            Background="#9C27B0"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button Content="💾 保存配置"
                            Command="{Binding SaveConfigCommand}"
                            Background="#607D8B"
                            Foreground="White"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主体内容 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：层级列表 ===== -->
            <ScrollViewer Grid.Column="0"
                          Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="📊 层级管理"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <ItemsControl ItemsSource="{Binding Levels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:LevelViewModel">
                                <controls:LevelItemControl/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== 右侧：控制面板 ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 可用进程列表（占据剩余空间） -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🎯 可用音频进程"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Background="#FAFAFA"
                                CornerRadius="6"
                                Padding="8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <ListBox x:Name="AvailableProcessListBox"
                                         ItemsSource="{Binding AvailableProcesses}"
                                         SelectedItem="{Binding SelectedAvailableProcess}"
                                         Margin="0,0,0,8"
                                         PreviewMouseMove="AvailableProcessListBox_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayInfo}"
                                                       FontWeight="Medium"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="💡 拖拽上方进程到左侧层级即可添加"
                                           Style="{StaticResource ThinMutedStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 使用说明（固定在底部） -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="ℹ️ 使用说明"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Background="#FFF8E1"
                            CornerRadius="6"
                            Padding="10"
                            BorderBrush="#FFE082"
                            BorderThickness="1">
                        <StackPanel TextBlock.FontSize="11"
                                    TextBlock.Foreground="#666">
                            <TextBlock Text="1. 从右侧「可用音频进程」拖拽到左侧层级即可添加"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="2. 点击「启动监控」开始自动音量调节"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="3. 当上级软件播放声音时，下级音量自动降低到目标音量"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="4. 层级 0 为最高优先级，越往下优先级越低"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="5. 使用「添加/删除层级」按钮管理层级数量"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="6. 拖动滑块可调整每个层级的目标音量"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="7. 点击层级名称可直接编辑"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="8. 配置会自动保存到 config.json"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== 底部状态栏 ===== -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                CornerRadius="6"
                Padding="8"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="💡"
                           FontSize="14"
                           Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Style="{StaticResource ThinSecondaryStyle}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="层级: "
                               Style="{StaticResource ThinMutedStyle}"/>
                    <TextBlock Text="{Binding Levels.Count}"
                               Style="{StaticResource ThinMutedStyle}"/>
                    <TextBlock Text=" | 监控: "
                               Style="{StaticResource ThinMutedStyle}"/>
                    <TextBlock FontSize="11"
                               Foreground="#999">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"
                                        Value="运行中"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}"
                                                 Value="False">
                                        <Setter Property="Text"
                                                Value="已停止"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
