<Application x:Class="AdaptiveVolumeMixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdaptiveVolumeMixer.Converters">
        <Application.Resources>

                <!-- ===== 全局转换器 ===== -->
                <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
                <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
                <converters:NullToBoolConverter x:Key="NullToBool"/>
                <converters:LevelIndexToColorBrushConverter x:Key="LevelIndexToColor"/>

                <!-- ===== 全局颜色资源 ===== -->
                <SolidColorBrush x:Key="PlayingColor"
                                 Color="#4CAF50"/>
                <SolidColorBrush x:Key="SuppressedColor"
                                 Color="#FF9800"/>
                <SolidColorBrush x:Key="IdleColor"
                                 Color="#9E9E9E"/>

                <!-- ===== 布局样式 ===== -->

                <!-- 进程列表项卡片 -->
                <Style x:Key="ProcessItemStyle"
                       TargetType="Border">
                        <Setter Property="Background"
                                Value="#F5F5F5"/>
                        <Setter Property="BorderBrush"
                                Value="#E0E0E0"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="CornerRadius"
                                Value="4"/>
                        <Setter Property="Margin"
                                Value="4,2"/>
                        <Setter Property="Padding"
                                Value="8,6"/>
                </Style>

                <!-- 层级容器（含拖拽高亮效果） -->
                <Style x:Key="LevelDropTargetStyle"
                       TargetType="Border">
                        <Setter Property="Background"
                                Value="#FAFAFA"/>
                        <Setter Property="CornerRadius"
                                Value="6"/>
                        <Setter Property="Margin"
                                Value="0,0,0,8"/>
                        <Setter Property="Padding"
                                Value="0"/>
                        <Setter Property="BorderBrush"
                                Value="#E0E0E0"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Style.Triggers>
                                <Trigger Property="Tag"
                                         Value="DragOver">
                                        <Setter Property="BorderBrush"
                                                Value="#2196F3"/>
                                        <Setter Property="BorderThickness"
                                                Value="2"/>
                                        <Setter Property="Background"
                                                Value="#E3F2FD"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ===== 按钮样式 ===== -->

                <!-- 工具栏按钮（白色文字、统一间距） -->
                <Style x:Key="ToolbarButtonStyle"
                       TargetType="Button">
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="Padding"
                                Value="12,6"/>
                        <Setter Property="Margin"
                                Value="0,0,6,0"/>
                </Style>

                <!-- 删除图标按钮（透明背景、红色 ✕） -->
                <Style x:Key="DeleteIconButtonStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="#F44336"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="Width"
                                Value="24"/>
                        <Setter Property="Height"
                                Value="24"/>
                </Style>

                <!-- ===== 文本样式 ===== -->

                <!-- 微小文字（灰色，用于辅助信息） -->
                <Style x:Key="ThinMutedStyle"
                       TargetType="TextBlock">
                        <Setter Property="FontSize"
                                Value="11"/>
                        <Setter Property="Foreground"
                                Value="#999999"/>
                </Style>

                <!-- 微小文字（深灰，用于次要标签） -->
                <Style x:Key="ThinSecondaryStyle"
                       TargetType="TextBlock">
                        <Setter Property="FontSize"
                                Value="11"/>
                        <Setter Property="Foreground"
                                Value="#666666"/>
                </Style>

        </Application.Resources>
</Application>
